# MongoDB 连接字符串 (本地开发)
MONGODB_URI=mongodb://localhost:27017/universal_journal

# 生产环境使用 (MongoDB Atlas 等)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/journal?retryWrites=true&w=majority

# JWT 密钥 (生产环境请使用强随机字符串)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 端口
PORT=4000

# CORS 允许的前端域名
FRONTEND_URL=http://localhost:3000
