# 万物手札后端配置 (SQLite)
# 数据库文件自动创建于 server/data/journal.db

# JWT 密钥 (生产环境请使用强随机字符串)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 端口
PORT=4000

# CORS 允许的前端域名 (同域部署时无需设置)
FRONTEND_URL=http://localhost:3000

# 是否提供前端静态文件 (生产环境设为 true)
SERVE_FRONTEND=true

# 前端静态文件目录
FRONTEND_DIR=../dist
